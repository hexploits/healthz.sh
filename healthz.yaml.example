# Endpoints to monitor
checks:
  - name: My API
    url: https://api.example.com/health
    interval: 1m
    timeout: 10s
    expected_status: 200

  - name: My Website
    url: https://example.com
    interval: 1m
    timeout: 10s
    expected_status: 200

# Regions to run health checks from (one Lambda per region)
regions:
  - us-east-1
  - eu-west-1

settings:
  # Where the dashboard (S3 + CloudFront + API Gateway) and
  # the master DynamoDB table are deployed. Replicas are created
  # in all other regions listed above.
  primary_region: us-east-1

  # How long to keep check results (DynamoDB TTL)
  retention_days: 180

  # DynamoDB table name (shared across all regions)
  table_name: healthz-checks

# Custom domain (optional)
# Option A — External DNS (Cloudflare, etc.):
#   Just set names. The deploy script requests the cert, prints validation
#   records to add, and completes on re-run once validated.
# Option B — Route53:
#   Set names + hosted_zone_id + zone_name. Fully automated.
# domain:
#   names:
#     - status.example.com
#   hosted_zone_id: Z0123456789
#   zone_name: example.com

# Branding shown on the dashboard (all optional)
branding:
  company_name: My Company           # header text (fallback when no logo)
  company_url: https://example.com   # header links here
  # theme_mode: both                 # "both" (default), "dark", or "light"
  # primary_color: "#3717EB"         # hex color for headings and brand text

# Logo: place logo-dark.png and/or logo-light.png in packages/ui/public/
# Either or both can be provided. Falls back to company_name text if absent.

# Font: place font files in packages/ui/public/fonts/ and update the
# @font-face src paths in packages/ui/src/app/globals.css
